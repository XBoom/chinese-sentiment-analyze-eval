# 复制为 .env：cp .env.example .env
# 下列键必须全部存在且合法；程序不为业务配置提供默认值（缺失即退出）。
# MAX_SAMPLES 留空、none 或 null 表示全量；否则须为正整数。
# OUTPUT_DIR 填 . 表示报告写在脚本所在目录。

MODEL_NAME=uer/roberta-base-finetuned-jd-binary-chinese
DATASET_NAME=tyqiangz/multilingual-sentiments
DATASET_CONFIG=chinese
DATASET_SPLIT=test
MAX_SAMPLES=
DEVICE=-1
BATCH_SIZE=32
MAX_LENGTH=256
OUTPUT_DIR=.
